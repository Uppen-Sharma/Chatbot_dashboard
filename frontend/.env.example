# Frontend environment variables — copy to .env and fill in values.

# Local dev: http://localhost:5000/api  |  Production: /api
VITE_API_URL=http://localhost:5000/api

# dev  → mock login via localStorage (no Azure needed locally)
# prod → redirects to /oauth2/sign_in (handled by oauth2-proxy + Azure AD)
VITE_AUTH_MODE=dev
