# Backend environment variables — copy to .env and fill in values.

ENV=dev
PORT=5000

# Comma-separated allowed frontend origins
ALLOWED_CORS_ORIGINS=http://localhost:5173

DB_URL=mysql+aiomysql://username:password@localhost:3306/chatbot
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# dev  → mock admin user injected (no Azure needed locally)
# prod → requires X-Auth-Request-Email header from oauth2-proxy
AUTH_MODE=dev

# Comma-separated emails with admin access (delete, upload, translate)
ADMIN_EMAILS=admin@yourdomain.com
